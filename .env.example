# OpenRouter API key — used for generation, reranking, AND embeddings
# Set this on Pi to avoid loading any local model (zero RAM for ML)
OPENROUTER_API_KEY=sk-or-...

# Cloudflare AI Gateway (optional)
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_GATEWAY_ID=your_gateway_name

# Postgres
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal
POSTGRES_DB=legalrag
DATABASE_URL=postgresql://legal:legal@localhost:5435/legalrag

# Model slots (overridable)
GEN_MODEL=anthropic/claude-sonnet-4-5
HYDE_MODEL=openai/gpt-4.1-mini
RERANKER_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free
# Locked embedding model — baai/bge-m3 (1024-dim, multilingual, stable)
# Asymmetry via manual query prefix in embed.py — do NOT change without re-ingesting all demos
EMBED_MODEL=baai/bge-m3

# CORS — comma-separated origins the API allows
# Add your production tunnel URLs here when deploying
CORS_ORIGINS=http://localhost:3002

# Web
# Local dev (Mac):
NEXT_PUBLIC_API_URL=http://localhost:8000
# Pi via Cloudflare Tunnel (uncomment on Pi):
# NEXT_PUBLIC_API_URL=https://vidhi-api.shubhammathur.in

# ── Port map (Raspberry Pi) ───────────────────────────────────────────────────
# DB  → 5435 (ParadeDB)
# API → 8000 (FastAPI)   tunnel: vidhi-api.shubhammathur.in
# Web → 3002 (Next.js)   tunnel: vidhi.shubhammathur.in
#
# ── Raspberry Pi deployment notes ────────────────────────────────────────────
# qwen3-embedding-0.6b runs on CPU (~2-5s per query on Pi 4/5) — dev fallback only
# Production: OPENROUTER_API_KEY set → baai/bge-m3 via OpenRouter, zero local model
# Ingest is one-time — run on Mac, dump + SCP to Pi, restore
# No GPU required at query time
# Recommended: Pi 4 4GB+ or Pi 5
