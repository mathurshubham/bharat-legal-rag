# OpenRouter API key — used for generation, reranking, AND embeddings
# Set this on Pi to avoid loading any local model (zero RAM for ML)
# Free embedding model: nvidia/llama-nemotron-embed-vl-1b-v2:free
# When unset: falls back to local qwen3-embedding-0.6b (requires 1.2GB RAM)
OPENROUTER_API_KEY=sk-or-...

# Cloudflare AI Gateway
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_GATEWAY_ID=your_gateway_name

# OpenRouter key — passed as header from UI, but can set here for API direct use
# OPENROUTER_API_KEY=sk-or-...

# Postgres
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal
POSTGRES_DB=legalrag
DATABASE_URL=postgresql://legal:legal@localhost:5435/legalrag

# Model slots (overridable)
# Cohere key for reranking (passed as X-Cohere-Key header from UI, or set here)
# Free tier: 1000 calls/month — sufficient for demos
# If absent, reranking is skipped and top_n taken direct from retrieval
# COHERE_API_KEY=...

GEN_MODEL=anthropic/claude-sonnet-4-5
HYDE_MODEL=openai/gpt-4.1-mini
RERANKER_MODEL=rerank-v3.5
EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Web
# Local dev (Mac):
NEXT_PUBLIC_API_URL=http://localhost:8000
# Pi via Cloudflare Tunnel (uncomment on Pi):
# NEXT_PUBLIC_API_URL=https://vidhi-api.shubhammathur.in

# ── Port map (Raspberry Pi) ───────────────────────────────────────────────────
# DB  → 5435 (ParadeDB)
# API → 8000 (FastAPI)   tunnel: vidhi-api.shubhammathur.in
# Web → 3002 (Next.js)   tunnel: vidhi.shubhammathur.in
#
# Add to /etc/cloudflared/config.yml on Pi:
#   - hostname: vidhi.shubhammathur.in
#     service: http://localhost:3002
#   - hostname: vidhi-api.shubhammathur.in
#     service: http://localhost:8000
#
# ── Raspberry Pi deployment notes ────────────────────────────────────────────
# qwen3-embedding-0.6b runs on CPU (~2-5s per query on Pi 4/5)
# Ingest is one-time — run on Mac, dump + SCP to Pi, restore
# No GPU required at query time
# Recommended: Pi 4 4GB+ or Pi 5
